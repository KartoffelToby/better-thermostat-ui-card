{
  "name": "better-thermostat-ui-card",
  "version": "3.2.0",
  "description": "Lovelace better-thermostat-ui",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "automation",
    "lovelace",
    "custom-cards",
    "better-thermostat",
    "better_thermostat"
  ],
  "module": "better-thermostat-ui-card.js",
  "repository": "https://github.com/KartoffelToby/better-thermostat-ui-card",
  "author": "Tobias Haber",
  "scripts": {
    "start": "rollup -c --bundleConfigAsCjs --watch",
    "build": "rollup -c --bundleConfigAsCjs",
    "format": "prettier --write src test",
    "lint": "eslint src test",
    "test": "bun test",
    "start:hass-stable": "docker run --pull always --rm -p 8123:8123 -v ./.dev:/config homeassistant/home-assistant:stable",
    "start:hass": "docker run --rm --pull always -p 8123:8123 -v ./.dev:/config homeassistant/home-assistant:beta",
    "start:hass-dev": "docker run --pull always --rm -p 8123:8123 -v ./.dev:/config homeassistant/home-assistant:dev",
    "typecheck": "tsc -p tsconfig.json"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@lit-labs/observers": "^2.1.0",
    "@mdi/js": "^7.4.47",
    "lit": "^3.3.3",
    "memoize-one": "^6.0.0",
    "mushroom-cards": "github:piitaya/lovelace-mushroom#3f0c3d15f9116931af194cd6abbe74c8ac4d692e",
    "superstruct": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "^1.3.5",
    "@material/mwc-icon": "^0.27.0",
    "@material/mwc-list": "^0.27.0",
    "@material/mwc-menu": "^0.27.0",
    "@material/mwc-notched-outline": "^0.27.0",
    "@material/mwc-ripple": "^0.27.0",
    "@rollup/plugin-commonjs": "28.0.6",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.12.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.1.1",
    "prettier": "^3.8.3",
    "rollup": "4.46.2",
    "rollup-plugin-serve": "^3.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
